### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#cdcac4'
set completion-bg '#06080B'

# Command line completion group elements
set completion-group-fg '#6D7077'
set completion-group-bg '#06080B'

# Current command line completion element
set completion-highlight-fg '#06080B'
set completion-highlight-bg '#cdcac4'

# Default foreground/background color
set default-bg rgba(6,8,11,1)

# Input bar
set inputbar-fg '#cdcac4'
set inputbar-bg '#06080B'

# Notification
set notification-fg '#cdcac4'
set notification-bg '#06080B'

# Error notification
set notification-error-fg '#cdcac4'
set notification-error-bg '#535B67'

# Warning notification
set notification-warning-fg '#cdcac4'
set notification-warning-bg '#535B67'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#cdcac4'
set statusbar-bg '#06080B'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#6D7077'
set highlight-active-color '#6D7077'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#cdcac4'

# 'Loading...' text
set render-loading-fg '#cdcac4'
set render-loading-bg '#06080B'

# Index mode
set index-fg '#cdcac4'
set index-bg '#06080B'

# Selected element in index mode
set index-active-fg '#06080B'
set index-active-bg '#cdcac4'